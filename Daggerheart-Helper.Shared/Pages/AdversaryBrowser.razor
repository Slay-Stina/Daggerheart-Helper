@page "/dm-tools/adversaries"
@inject IAdversaryCatalogQueries AdversaryQueries
@inject NavigationManager NavigationManager

<PageTitle>Adversary Browser — DM Tools</PageTitle>

<div class="dashboard-container">
    <div class="dashboard-header">
        <div class="header-text">
            <h2>Adversary Browser</h2>
            <p>Browse and search Daggerheart adversaries from the SRD</p>
        </div>
        <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Filled.Size20.ArrowLeft())" OnClick="@GoBack">
            Back to DM Tools
        </FluentButton>
    </div>

    <div class="filters-bar">
        <FluentTextField Placeholder="Search by name..." Value="@_searchTerm" ValueChanged="@OnSearchChanged" Style="max-width: 250px;" Immediate ImmediateDelay="300" />
        <select @onchange="@OnTypeChanged" class="filter-select" value="@_selectedTypeStr">
            <option value="">All Types</option>
            <option value="Solo">Solo</option>
            <option value="Bruiser">Bruiser</option>
            <option value="Horde">Horde</option>
            <option value="Leader">Leader</option>
            <option value="Minion">Minion</option>
            <option value="Ranged">Ranged</option>
            <option value="Skulk">Skulk</option>
            <option value="Social">Social</option>
            <option value="Standard">Standard</option>
            <option value="Support">Support</option>
        </select>
        <select @onchange="@OnTierChanged" class="filter-select" value="@_selectedTierStr">
            <option value="0">All Tiers</option>
            <option value="1">Tier 1</option>
            <option value="2">Tier 2</option>
            <option value="3">Tier 3</option>
            <option value="4">Tier 4</option>
            <option value="5">Tier 5</option>
        </select>
        <FluentButton Appearance="Appearance.Accent" IconStart="@(new Icons.Filled.Size20.Search())" OnClick="@ApplyFilters">Search</FluentButton>
    </div>

    @if (_loading)
    {
        <div class="loading-container">
            <FluentProgressRing />
            <p>Loading adversaries...</p>
        </div>
    }
    else if (!_adversaries.Any())
    {
        <div class="empty-state">
            <FluentIcon Value="@(new Icons.Filled.Size48.PeopleCommunity())" Color="Color.Neutral" />
            <h3>No adversaries found</h3>
            <p>Try adjusting your search or filter criteria.</p>
        </div>
    }
    else
    {
        <div class="result-count">@_adversaries.Count adversary@(_adversaries.Count != 1 ? "ies" : "y")</div>
        <FluentStack Orientation="Orientation.Vertical" Gap="8">
            <FluentDataGrid Items="@(_adversaries.AsQueryable())" 
                            GenerateHeader="GenerateHeaderOption.Sticky" 
                            Class="adversary-grid" 
                            ShowHover="@(true)" 
                            AutoFit="true" 
                            OnRowClick="@((FluentDataGridRow<AdversarySummary> row) => { if (row.Item is not null) ShowDetail(row.Item); })">
                    <PropertyColumn Property="@(a => a.Name)" Title="Name" Sortable="true" />
                    <TemplateColumn Title="Tier" Sortable="true" SortBy="@SortByTier" Align="Align.Center">
                        <span class="badge-tier">T@(context.Tier)</span>
                    </TemplateColumn>
                    <TemplateColumn Title="Type" Sortable="true" SortBy="@SortByType" Align="Align.Center">
                        <span class="badge-type type-@context.Type.ToString().ToLowerInvariant()">@context.Type</span>
                    </TemplateColumn>
                    <PropertyColumn Property="@(a => a.Difficulty)" Title="Difficulty" Sortable="true" Align="Align.Center" />
                    <PropertyColumn Property="@(a => a.Hp)" Title="HP" Sortable="true" Align="Align.Center" />
                    <PropertyColumn Property="@(a => a.Stress)" Title="Stress" Sortable="true" Align="Align.Center" />
                    <TemplateColumn Title="Thresholds" Sortable="true" SortBy="@SortByThreshold" Align="Align.Center">
                        <span>@(string.IsNullOrEmpty(context.Thresholds) ? "—" : context.Thresholds)</span>
                    </TemplateColumn>
            </FluentDataGrid>
        </FluentStack>
    }
</div>

@if (_selected is not null)
{
    <div class="detail-overlay" @onclick="@ClearSelection">
        <FluentCard class="detail-card" @onclick:stopPropagation>
            <div class="detail-header">
                <h3>@_selected.Name</h3>
                <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Filled.Size20.Dismiss())" OnClick="@ClearSelection" />
            </div>

            <div class="detail-subtitle">@_selected.Type — Tier @_selected.Tier</div>

            @if (!string.IsNullOrEmpty(_selected.Description))
            {
                <p class="detail-desc">@_selected.Description</p>
            }

            <div class="stat-block">
                <div class="stat-row-core">
                    <span class="stat-badge stat-dv">DV @_selected.Difficulty</span>
                    <span class="stat-badge stat-thr">@(!string.IsNullOrEmpty(_selected.Thresholds) ? _selected.Thresholds : "—")</span>
                    <span class="stat-badge stat-hp">HP @_selected.Hp</span>
                    <span class="stat-badge stat-sta">STA @_selected.Stress</span>
                </div>
                <div class="stat-row-attack">
                    <span class="stat-badge stat-atk">ATK @_selected.Attack</span>
                    <span class="stat-badge stat-rng">@_selected.Range</span>
                    <span class="stat-badge stat-dmg">@_selected.Damage</span>
                </div>
            </div>

            @if (_selected.Features.Count > 0)
            {
                <FluentDivider />
                <h4 class="features-heading">Features</h4>
                <FluentAccordion Class="detail-accordion" ExpandMode="AccordionExpandMode.Multi">
                    @foreach (var f in _selected.Features)
                    {
                        <FluentAccordionItem Heading="@f.Name">
                            <p>@f.Description.ToMarkdownHtml()</p>
                        </FluentAccordionItem>
                    }
                </FluentAccordion>
            }
        </FluentCard>
    </div>
}

@code {
    private List<AdversarySummary> _adversaries = [];
    private bool _loading = true;
    private string _searchTerm = string.Empty;
    private string _selectedTypeStr = "";
    private string _selectedTierStr = "0";
    private AdversarySummary? _selected;

    private static readonly GridSort<AdversarySummary> SortByTier = GridSort<AdversarySummary>.ByAscending(a => a.Tier);
    private static readonly GridSort<AdversarySummary> SortByType = GridSort<AdversarySummary>.ByAscending(a => a.Type.ToString());
    private static readonly GridSort<AdversarySummary> SortByThreshold = GridSort<AdversarySummary>.ByAscending(a => a.Thresholds);

    protected override async Task OnInitializedAsync()
    {
        await LoadAdversaries();
    }

    private async Task LoadAdversaries()
    {
        _loading = true;
        try
        {
            _adversaries = await AdversaryQueries.GetAllAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private void OnSearchChanged(string value)
    {
        _searchTerm = value;
        _ = ApplyFilters();
    }

    private async Task OnTypeChanged(ChangeEventArgs e)
    {
        _selectedTypeStr = e.Value?.ToString() ?? "";
        await ApplyFilters();
    }

    private async Task OnTierChanged(ChangeEventArgs e)
    {
        _selectedTierStr = e.Value?.ToString() ?? "0";
        await ApplyFilters();
    }

    private async Task ApplyFilters()
    {
        _loading = true;
        try
        {
            AdversaryType? type = null;
            if (Enum.TryParse<AdversaryType>(_selectedTypeStr, ignoreCase: true, out var parsed))
                type = parsed;

            var tier = int.TryParse(_selectedTierStr, out var t) ? t : 0;

            _adversaries = await AdversaryQueries.SearchAsync(
                _searchTerm,
                type,
                tier is 0 ? null : tier,
                null, null);
        }
        finally
        {
            _loading = false;
        }
    }

    private void ShowDetail(AdversarySummary adv)
    {
        _selected = adv;
    }

    private void ClearSelection()
    {
        _selected = null;
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/dm-tools");
    }
}
